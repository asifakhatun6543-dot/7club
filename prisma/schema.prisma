generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String
  passwordHash  String
  role          String   @default("USER")
  vip           Boolean  @default(false)
  createdAt     DateTime @default(now())
  history       History[]
  watchlist     Watchlist[]
  likes         Like[]
  downloads     Download[]
}

model Content {
  id            String   @id @default(cuid())
  title         String
  description   String
  slug          String   @unique
  type          String
  categories    String
  genres        String
  country       String
  year          Int
  poster        String
  banner        String
  externalUrl   String
  embedUrl      String?
  qualities     String
  subtitles     String
  isVip         Boolean  @default(false)
  releaseDate   DateTime @default(now())
  createdAt     DateTime @default(now())
  episodes      Episode[]
  likes         Like[]
  watchlist     Watchlist[]
  downloads     Download[]
  history       History[]
}

model Episode {
  id          String   @id @default(cuid())
  title       String
  number      Int
  season      Int
  content     Content  @relation(fields: [contentId], references: [id])
  contentId   String
  externalUrl String
  preview     String?
  isLocked    Boolean  @default(false)
}

model History {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  content    Content  @relation(fields: [contentId], references: [id])
  contentId  String
  progress   Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model Watchlist {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  content   Content  @relation(fields: [contentId], references: [id])
  contentId String
}

model Like {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  content   Content  @relation(fields: [contentId], references: [id])
  contentId String
}

model Download {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  content   Content  @relation(fields: [contentId], references: [id])
  contentId String
  quality   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  expiresAt DateTime
}
